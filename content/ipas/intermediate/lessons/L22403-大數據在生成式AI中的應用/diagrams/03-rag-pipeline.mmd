flowchart TD
    subgraph INDEX["📚 索引建立 (離線)"]
        DOCS["原始文件\n(PDF/Word/網頁)"]
        CHUNK["文件分塊 Chunking\nFixed-size: 256–512 tokens\nSemantic: 句子邊界\nRecursive: LangChain Splitter"]
