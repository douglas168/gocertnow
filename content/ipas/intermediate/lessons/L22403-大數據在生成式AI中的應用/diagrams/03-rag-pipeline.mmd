    end

    subgraph QUERY["🔎 查詢推論 (線上)"]
        Q["使用者問題"]
        QE["問題嵌入\n同一嵌入模型"]
        RET["相似度搜尋\ncosine similarity / ANN"]
        CTX["Top-K 相關段落"]
        PROMPT["Prompt 組合\n問題 + 上下文"]
        LLM["LLM 生成回答\nmodel.generate()"]
        Q --> QE --> RET --> CTX --> PROMPT --> LLM
    end

    VDB --> RET

